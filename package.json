{
  "name": "hoo-browser",
  "productName": "Hoo Browser",
  "version": "0.1.0",
  "description": "A DuckDuckGo-first desktop browser experiment with owl-led UX, practical privacy controls, Linux web-app compatibility, and local-first AI assistance.",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "build:prod": "cross-env NODE_ENV=production webpack --config webpack.config.js",
    "dev": "cross-env NODE_ENV=development webpack --config webpack.config.js --watch",
    "start": "electron .",
    "start:unsafe-no-sandbox": "electron . --no-sandbox",
    "dev:start": "npm run build && npm run start",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run build",
    "dist": "npm run build:prod && electron-builder --linux AppImage deb --x64",
    "dist:appimage": "npm run build:prod && electron-builder --linux AppImage --x64",
    "dist:deb": "npm run build:prod && electron-builder --linux deb --x64"
  },
  "keywords": [
    "electron",
    "browser",
    "duckduckgo",
    "privacy",
    "linux",
    "desktop-app",
    "owl"
  ],
  "author": "Imran Shiundu",
  "license": "MIT",
  "build": {
    "appId": "africa.hoo.browser",
    "productName": "Hoo Browser",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "desktop": {
        "Name": "Hoo Browser",
        "Comment": "DuckDuckGo-first browser with isolated web apps",
        "Categories": "Network;WebBrowser;"
      }
    }
  },
  "devDependencies": {
    "@types/electron": "^1.4.38",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "copy-webpack-plugin": "^13.0.1",
    "cross-env": "^10.1.0",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "html-webpack-plugin": "^5.6.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "css-loader": "^7.1.3",
    "lucide-react": "^0.563.0",
    "megajs": "^1.3.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "style-loader": "^4.0.0"
  }
}
